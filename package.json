{
  "name": "app",
  "version": "1.0.0",
  "description": "GraphHarness Studio delivers a data-first, variant-aware wire-harness CAD tool. Using Electron, React, and Neo4j, it provides engineers a synced table-and-canvas experience, instant rule validation, and industrial-grade exports—while strictly adhering to modern security and performance standards.",
  "main": "dist/main/main.js",
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "start": "electron .",
    "dev": "vite",
    "build:vite": "tsc && vite build",
    "build:electron": "tsc -p tsconfig.json --outDir dist/main && cp src/preload.ts dist/main/preload.js",
    "build": "npm run build:vite && npm run build:electron",
    "db:seed": "NODE_ENV=development ts-node src/scripts/seed-db.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Delles/GraphHarness-Studio.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Delles/GraphHarness-Studio/issues"
  },
  "homepage": "https://github.com/Delles/GraphHarness-Studio#readme",
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/ui": "^3.2.3",
    "c8": "^10.1.3",
    "electron": "^36.4.0",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.5.3",
    "prisma": "^6.9.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@reduxjs/toolkit": "^2.8.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "neo4j-driver": "^5.28.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.6.2",
    "winston": "^3.17.0",
    "zod": "^3.25.64"
  }
}
